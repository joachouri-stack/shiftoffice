# Shift Office — variables d'environnement
# Copiez ce fichier en .env.local (dev) ou configurez-les sur le serveur (prod).

# ── Anthropic (Claude) ──────────────────────────────────────────────────────
# Requise pour l'Assistant IA et la génération des devis/emails.
# À créer sur https://console.anthropic.com/ (facturation à l'usage).
# Sans cette clé, l'IA affiche un message d'invitation / un gabarit de repli.
ANTHROPIC_API_KEY=

# ── Supabase (auth + base de données) ───────────────────────────────────────
# À créer sur https://supabase.com → Project Settings → API.
# Tant que ces valeurs sont vides, l'app fonctionne en mode local-first.
# Les deux premières sont exposées au navigateur (préfixe NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role — SERVEUR UNIQUEMENT, ne jamais exposer au client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (envoi des emails) ───────────────────────────────────────────────
# À créer sur https://resend.com. Domaine d'envoi à vérifier (shiftoffice.fr).
RESEND_API_KEY=
RESEND_FROM_EMAIL=devis@shiftoffice.fr
RESEND_FROM_NAME=Shift Office

# ── Stripe (abonnements) ────────────────────────────────────────────────────
# À créer sur https://dashboard.stripe.com.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESSENTIEL=
STRIPE_PRICE_PRO=

# ── Application ─────────────────────────────────────────────────────────────
# URL publique du site (sert aux redirections OAuth et aux liens des emails).
NEXT_PUBLIC_APP_URL=http://localhost:3000
