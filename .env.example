# Variables d'environnement — Shift Office
# Copiez ce fichier en .env.local (dev) ou configurez-les sur le serveur (prod).

# --- Paiement Stripe -------------------------------------------------------
# Tant que STRIPE_SECRET_KEY est absente, les documents payants sont générés
# directement (mode transition). Dès qu'elle est présente, le paiement est
# exigé : bouton « Payer » -> Stripe Checkout -> génération du PDF.
STRIPE_SECRET_KEY=

# URL publique du site, utilisée pour les redirections Stripe (success/cancel).
# Ex. https://shiftoffice.fr  (sinon déduite de la requête).
NEXT_PUBLIC_SITE_URL=

# --- IA (déjà en place) ----------------------------------------------------
# ANTHROPIC_API_KEY=
