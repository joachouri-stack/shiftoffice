# Variables d'environnement — Shift Office
# Copiez ce fichier en .env.local (dev) ou configurez-les sur le serveur (prod).

# --- Paiement Stripe -------------------------------------------------------
# Tant que STRIPE_SECRET_KEY est absente, les documents payants sont générés
# directement (mode transition). Dès qu'elle est présente, le paiement est
# exigé : bouton « Payer » -> Stripe Checkout -> génération du PDF.
STRIPE_SECRET_KEY=

# URL publique du site, utilisée pour les redirections Stripe (success/cancel).
# Ex. https://shiftoffice.fr  (sinon déduite de la requête).
NEXT_PUBLIC_SITE_URL=

# --- Comptes & historique : Supabase ---------------------------------------
# Tant que ces variables sont absentes, /connexion et /compte affichent un avis
# « bientôt disponible » et le site fonctionne sans compte. Dès qu'elles sont
# présentes : connexion Google, historique des documents, salariés, profil.
# ⚠️ Variables NEXT_PUBLIC_* : doivent être définies AVANT le build (Coolify).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Email du PDF : Resend -------------------------------------------------
# Sans RESEND_API_KEY, l'option « Recevoir par email » est masquée. Avec elle,
# le PDF peut être envoyé en pièce jointe. EMAIL_FROM doit utiliser un domaine
# vérifié dans Resend (par défaut : onboarding@resend.dev pour les tests).
RESEND_API_KEY=
EMAIL_FROM="Shift Office <documents@shiftoffice.fr>"

# --- IA (déjà en place) ----------------------------------------------------
# ANTHROPIC_API_KEY=
